# Copy this file to .env and fill in real values. Never commit the real .env.

# Gemini API key (Google AI Studio free tier, no billing card required) —
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Secret used to sign login session tokens (JWT). Use a long random string —
# e.g. generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

PORT=4000
