# Copy this file to .env and fill in real values. Never commit the real .env.

# Anthropic Claude API key — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Secret used to sign login session tokens (JWT). Use a long random string —
# e.g. generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

PORT=4000
